<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Estoque"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:checkedButton="@+id/btnToggleArmario"
        app:singleSelection="true">
        <Button android:id="@+id/btnToggleArmario" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Armário" />
        <Button android:id="@+id/btnToggleItem" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Item" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- ARMÁRIO -->
    <LinearLayout
        android:id="@+id/layoutEditArmario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecionar Armário:"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteArmario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar armário..."
                android:inputType="textCapWords"
                android:completionThreshold="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox
            android:id="@+id/checkAlterarNomeArmario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alterar nome do armário"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutNovoNomeArmario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editNovoNomeArmario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Novo nome do Armário"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- ITEM -->
    <LinearLayout
        android:id="@+id/layoutEditItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecionar Item:"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar item..."
                android:inputType="textCapWords"
                android:completionThreshold="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox
            android:id="@+id/checkAlterarNomeItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alterar nome do item"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutNovoNomeItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editNovoNomeItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Novo nome do Item"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox
            android:id="@+id/checkAlterarLocalItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alterar armário do item"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutMoverParaArmario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:visibility="gone">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteArmarioDestino"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar armário destino..."
                android:inputType="textCapWords"
                android:completionThreshold="1" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnConfirmarEdit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Salvar Alteração"
        android:layout_marginTop="24dp" />

</LinearLayout>