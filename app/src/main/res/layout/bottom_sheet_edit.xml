<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Editar Estoque"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:checkedButton="@+id/btnToggleLocker"
        app:singleSelection="true">
        <Button android:id="@+id/btnToggleLocker" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Armário" />
        <Button android:id="@+id/btnToggleItem" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Item" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- ARMÁRIO -->
    <LinearLayout
        android:id="@+id/layoutEditLocker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecionar Armário:"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteLocker"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Buscar armário..."
                android:inputType="textCapWords"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:completionThreshold="0" />
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox
            android:id="@+id/checkChangeLockerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alterar nome do armário"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutNewLockerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editNewLockerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Novo nome do Armário"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgPreviewLocker"
                android:layout_width="80dp"
                android:layout_height="60dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btnLockerPhoto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alterar foto" />

            <Button
                android:id="@+id/btnRemoverLockerPhoto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remover foto"
                android:layout_marginStart="8dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- ITEM -->
    <LinearLayout
        android:id="@+id/layoutEditItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecionar Item:"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar item..."
                android:inputType="textCapWords"
                android:completionThreshold="0" />
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox
            android:id="@+id/checkChangeItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alterar nome do item"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutNewItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editNewItemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Novo nome do Item"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox
            android:id="@+id/checkChangeItemLoc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alterar armário do item"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutMoveToLocal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:visibility="gone">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteDestityLocker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar armário destino..."
                android:inputType="textCapWords"
                android:completionThreshold="0" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgPreviewItem"
                android:layout_width="80dp"
                android:layout_height="60dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btnItemPhoto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alterar foto" />

            <Button
                android:id="@+id/btnRemoveItemPhoto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Remover foto"
                android:layout_marginStart="8dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnConfirmEdit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Salvar Alteração"
        android:layout_marginTop="24dp" />

</LinearLayout>