<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remover do Estoque"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:checkedButton="@+id/btnToggleArmario"
        app:singleSelection="true">
        <Button android:id="@+id/btnToggleArmario" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Armário" />
        <Button android:id="@+id/btnToggleItem" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Item" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- ARMÁRIO: selecionar + destino dos itens -->
    <LinearLayout
        android:id="@+id/layoutDeleteArmario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Armário a remover:"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerArmarioParaRemover"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mover itens para:"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerDestinoItens"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <TextView
            android:id="@+id/txtAvisoSemDestino"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Nenhum outro armário disponível. Os itens serão deletados junto."
            android:textColor="#B00020"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ITEM: só selecionar qual remover -->
    <LinearLayout
        android:id="@+id/layoutDeleteItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Item a remover:"
            android:textColor="@color/black"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerItemParaRemover"
            android:layout_width="match_parent"
            android:layout_height="48dp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnConfirmarDelete"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Confirmar Remoção"
        android:backgroundTint="#B00020"
        android:layout_marginTop="24dp" />

</LinearLayout>